# ─────────────────────────────────────────────────────────────────────────────
# FinVault — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=finvault
POSTGRES_USER=finvault_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# ── JWT (generate with: openssl rand -base64 64) ──────────────────────────────
JWT_SECRET=CHANGE_ME_minimum_32_characters_random_string_here
JWT_REFRESH_SECRET=CHANGE_ME_different_minimum_32_chars_random_string
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ── Frontend ──────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_ENV=development

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password_here

# ── SSL (production only) ─────────────────────────────────────────────────────
# DB_SSL=true

# ── External services (optional) ─────────────────────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# FROM_EMAIL=noreply@finvault.app

# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
